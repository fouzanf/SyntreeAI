# SyntreeAI Backend Configuration Template

# Gemini API Key for code understanding and Q&A streams
GEMINI_API_KEY=your_gemini_api_key_here

# Neon / PostgreSQL Database URL (with pgvector extension)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Allowed CORS Origins (comma separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# (Optional) GitHub Token to bypass public API rate limits during PR reviews
GITHUB_TOKEN=your_github_token_here
